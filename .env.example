# ==========================================
# IDENTIDAD DE LA APP
# ==========================================
APP_NAME = "MyApp"
APP_BUNDLE_ID = "com.example.app"
APP_VERSION = "1.0.0"
APP_BUILD_NUMBER = "1"

# ==========================================
# URLs
# ==========================================
BASE_URL="https://example.com/"
PRIVACY_POLICY_URL="https://example.com/privacy"
AGENDA_URL="https://example.com/agenda/"
WHATSAPP_NUMBER="50768984998"
GOOGLE_MAPS_URL="https://maps.app.goo.gl/Q9TG27dRxv8aTXbC8"

# ==========================================
# REDES SOCIALES (se abren en app nativa)
# ==========================================
INSTAGRAM_URL="https://www.instagram.com/mi_cuenta"
TIKTOK_URL="https://www.tiktok.com/@mi_cuenta"

# ==========================================
# FIRMA ANDROID (build.gradle.kts lo lee)
# ==========================================
ANDROID_STORE_PASSWORD=tu_password_aqui
ANDROID_KEY_PASSWORD=tu_password_aqui
ANDROID_KEY_ALIAS=upload
ANDROID_KEYSTORE_PATH=../app/upload-keystore.jks

# ==========================================
# iOS - REFERENCIA (se edita en Xcode/xcconfig)
# ==========================================
# Archivo: ios/Runner.xcodeproj/project.pbxproj
# PRODUCT_BUNDLE_IDENTIFIER = com.tuempresa.app
#
# Archivo: ios/Runner/Info.plist
# CFBundleDisplayName = NombreApp
# NSAppTransportSecurity.NSAllowsArbitraryLoads = true
#
# Para subir a App Store: requiere Apple Developer Program ($99/año)
